# rag-engine/.env.example

# Server-side fallback keys (local-dev convenience only — the frontend
# sends per-request X-OpenAI-Key / X-Groq-Key headers which always take
# precedence; see KeySetup.tsx and backend/api/dependencies.py).
OPENAI_API_KEY=sk-...
GROQ_API_KEY=gsk_...

# Optional: override the ChromaDB storage path. Defaults to
# backend/ingestion/chroma_db/ (anchored to store.py's own location).
# Docker sets this to /app/chroma_db to match the mounted volume.
# CHROMA_PATH=./chroma_db
