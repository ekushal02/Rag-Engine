chroma_db/
backend/chroma_db/
backend/ingestion/chroma_db/
backend/uploaded_docs/
backend/ingestion_log.json
uploaded_docs/
ingestion_log.json

# Next.js
frontend/.next/
frontend/node_modules/
frontend/out/

# macOS
.DS_Store

# Editor
.vscode/
.idea/
